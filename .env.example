# Server port (Vercel ignores this - it manages ports automatically)
PORT=3001

# Comma-separated list of allowed CORS origins
# On Vercel, set this to your deployment URL(s)
# Example: https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3001

# Set to "production" in Vercel to disable debug endpoints (e.g. /api/issuer/verify)
NODE_ENV=production
